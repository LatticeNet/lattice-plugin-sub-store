{
  "schema": "lattice.plugin.manifest.v2",
  "id": "latticenet.sub-store",
  "name": "Sub-Store companion",
  "type": "system",
  "capabilities": [
    "rpc:call",
    "http:operator-target"
  ],
  "version": "0.3.2-alpha.1",
  "publisher": "latticenet",
  "signature_ed25519": "f/SZDZaq0lEF7uN36pqtMIwhDXFKRwmjyOW/YN92DDFFnLDtEwSV5P8lgOacU4p0uYfWL9jbyTqE68RpLuf4DQ==",
  "bundle": {
    "format": "tar+gzip",
    "digest_sha256": "4c4a511718286b11320a03b3ae69217d528b6dc5d2b52b2ac34b743a1b835eda"
  },
  "runtime": {
    "protocol": "stdio-json-v1",
    "entrypoints": {
      "linux/amd64": "bin/linux-amd64/plugin",
      "linux/arm64": "bin/linux-arm64/plugin"
    }
  },
  "ui_runtime": {
    "mode": "sandbox",
    "entrypoint": "ui/index.html",
    "bridge_version": "1"
  },
  "compatibility": {
    "server": "\u003e=0.2.1",
    "dashboard_host": "\u003e=1",
    "runtime_protocol": "\u003e=1"
  },
  "host_access": {
    "rpc": [
      {
        "service": "latticenet.vpn-core/nodes",
        "methods": [
          "export"
        ]
      }
    ]
  },
  "ui": {
    "nav": [
      {
        "section": "extensions",
        "section_title": "Extensions",
        "title": "Sub-Store",
        "route": "sub-store",
        "icon": "Store",
        "scopes": [
          "proxy:read"
        ]
      }
    ],
    "views": [
      {
        "route": "sub-store",
        "title": "Sub-Store",
        "kind": "sandbox"
      }
    ]
  },
  "interfaces": [
    {
      "service": "latticenet.sub-store/import",
      "methods": [
        {
          "name": "status",
          "effect": "read",
          "scopes": [
            "proxy:read"
          ],
          "operator_target_fields": [
            "base_url"
          ]
        },
        {
          "name": "import",
          "effect": "write",
          "scopes": [
            "proxy:admin"
          ],
          "operator_target_fields": [
            "base_url"
          ]
        }
      ]
    }
  ]
}
