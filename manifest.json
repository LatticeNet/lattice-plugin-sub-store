{
  "schema": "lattice.plugin.manifest.v2",
  "id": "latticenet.sub-store",
  "name": "Sub-Store companion",
  "type": "system",
  "capabilities": [
    "rpc:call",
    "http:operator-target",
    "secret:read",
    "secret:write"
  ],
  "version": "0.3.2-alpha.4",
  "publisher": "latticenet",
  "signature_ed25519": "ZQUeUAAbURhqqKdvrEwZZ5EgJ2jZt+BC3tMfOeJ5RY8Mh4fynLWxAyx0I7bDCZzZc+3QCgXdlDp9pN21ezoiAg==",
  "bundle": {
    "format": "tar+gzip",
    "digest_sha256": "913cfd76cd6c47a2ba62a2c9247b9786203f406200e0932a599c8c871779fd58"
  },
  "runtime": {
    "protocol": "stdio-json-v1",
    "entrypoints": {
      "linux/amd64": "bin/linux-amd64/plugin",
      "linux/arm64": "bin/linux-arm64/plugin"
    }
  },
  "ui_runtime": {
    "mode": "sandbox",
    "entrypoint": "ui/index.html",
    "bridge_version": "1"
  },
  "compatibility": {
    "server": "\u003e=0.2.2-alpha.2",
    "dashboard_host": "\u003e=1",
    "runtime_protocol": "\u003e=1"
  },
  "host_access": {
    "rpc": [
      {
        "service": "latticenet.vpn-core/nodes",
        "methods": [
          "export"
        ]
      }
    ]
  },
  "ui": {
    "nav": [
      {
        "section": "extensions",
        "section_title": "Extensions",
        "title": "Sub-Store",
        "route": "sub-store",
        "icon": "Store",
        "scopes": [
          "substore:read"
        ]
      }
    ],
    "views": [
      {
        "route": "sub-store",
        "title": "Sub-Store",
        "kind": "sandbox"
      }
    ]
  },
  "interfaces": [
    {
      "service": "latticenet.sub-store/import",
      "methods": [
        {
          "name": "status",
          "effect": "read",
          "scopes": [
            "substore:read"
          ],
          "operator_target_fields": [
            "base_url"
          ]
        },
        {
          "name": "preview",
          "effect": "read",
          "scopes": [
            "substore:read"
          ],
          "operator_target_fields": [
            "base_url"
          ]
        },
        {
          "name": "import",
          "effect": "write",
          "scopes": [
            "substore:admin"
          ],
          "operator_target_fields": [
            "base_url"
          ]
        },
        {
          "name": "endpoint_status",
          "effect": "read",
          "scopes": [
            "substore:read"
          ]
        },
        {
          "name": "save_endpoint",
          "effect": "write",
          "scopes": [
            "substore:admin"
          ]
        },
        {
          "name": "clear_endpoint",
          "effect": "write",
          "scopes": [
            "substore:admin"
          ]
        }
      ],
      "backing": "runtime"
    }
  ]
}
